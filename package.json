{
  "name": "lisovyi.net",
  "version": "0.0.1",
  "private": true,
  "description": "Build tool and dependencies for https://lisovyi.net",
  "scripts": {
    "prestart": "npm install",
    "watch-css": "postcss ./src/style.css -o ./assets/css/style.css --watch",
    "start": "concurrently \"npm run watch-css\" \"bundle exec jekyll serve\"",
    "build": "postcss ./src/styles.css -o ./dist/styles.css",
    "precommit": "npm run build"
  },
  "author": "Pavlo Lisovyi",
  "license": "ISC",
  "homepage": "https://github.com/plisovyi/lisovyi.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plisovyi/lisovyi.net.git"
  },
  "bugs": {
    "url": "https://github.com/plisovyi/lisovyi.net/issues"
  },
  "contributors": [
    {
      "name": "Pavlo Lisovyi",
      "email": "pavlo@lisovyi.net",
      "url": "https://lisovyi.net"
    }
  ],
  "devDependencies": {
    "postcss-cli": "5.0.0",
    "concurrently": "3.5.1"
  }
}
